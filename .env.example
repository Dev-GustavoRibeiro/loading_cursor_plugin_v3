# Optional environment variables for MCP integrations

# Context7
CONTEXT7_API_KEY=

# GitHub local / remote presets
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_TOOLSETS=context,repos,issues,pull_requests

# Optional self-host / special cases
GITHUB_HOST=

# Optional direct tokens when a remote MCP supports header auth
LINEAR_API_KEY=
SENTRY_ACCESS_TOKEN=
SENTRY_HOST=
